# open-sandbox environment variables
#
# Copy to .env (gitignored) and fill in. Each service binary reads what it
# needs from the environment; not every variable is needed by every binary.
# Required variables fail-closed: the service refuses to start if missing.
#
# Source of truth for variable names is crates/cli/src/cli.rs (clap `env =`
# attributes) and direct `std::env::var(...)` reads in crates/cli/src/run.rs
# and crates/contracts/src/constants.rs.

# ─────────────────────────────────────────────────────────────────────────────
# Shared
# ─────────────────────────────────────────────────────────────────────────────

# tracing-subscriber log filter. Examples: info, debug, open_sandbox=debug,info
RUST_LOG=info


# ─────────────────────────────────────────────────────────────────────────────
# Controller (open-sandbox controller)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Postgres connection URL. Contains the password — never logged.
OPEN_SANDBOX_DATABASE_URL=postgres://open_sandbox:CHANGE_ME@127.0.0.1:5432/open_sandbox

# gRPC listen port for agent connections. Default: 50051
OPEN_SANDBOX_CONTROLLER_GRPC_PORT=50051

# Dead-agent sweep interval in seconds. Default: 15
OPEN_SANDBOX_SWEEP_INTERVAL=15

# REQUIRED (fail-closed). Bearer token the api gateway and operators present
# on the controller's management gRPC. Generate with: openssl rand -hex 32
CONTROLLER_ADMIN_TOKEN=CHANGE_ME

# REQUIRED. Token agents present when calling Register on the controller.
# Generate with: openssl rand -hex 32
OPEN_SANDBOX_JOIN_TOKEN=CHANGE_ME


# ─────────────────────────────────────────────────────────────────────────────
# Proxy (open-sandbox proxy)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Same Postgres as the controller; the proxy reads the routing_entries
# table and LISTENs for invalidations.
# OPEN_SANDBOX_DATABASE_URL=...  (see above)

# Public HTTPS port for sandbox subdomain requests. Default: 8080
OPEN_SANDBOX_PROXY_HTTP_PORT=8080

# Public gRPC port — agents call OpenTunnel here. Default: 50052
OPEN_SANDBOX_PROXY_GRPC_PORT=50052

# Internal gRPC port — api gateway calls OpenIoStream here. In production this
# port MUST be network-isolated from the public internet (firewall to the api
# gateway's address only). Default: 50053
#
# Combined-listener mode (development only): set this equal to
# OPEN_SANDBOX_PROXY_GRPC_PORT to fall back to a single port. The proxy then
# REQUIRES OPEN_SANDBOX_INTERNAL_TOKEN to be set as the only auth on the
# combined surface; it refuses to start otherwise.
OPEN_SANDBOX_PROXY_INTERNAL_GRPC_PORT=50053

# REQUIRED (fail-closed). Token agents present on OpenTunnel. Without it any
# network-reachable caller can register as any agent_id and hijack routing.
# Generate with: openssl rand -hex 32
TUNNEL_JOIN_TOKEN=CHANGE_ME

# REQUIRED in combined-listener mode; STRONGLY RECOMMENDED in split-listener
# mode as defense in depth alongside network isolation. The api gateway must
# present this same value when calling OpenIoStream on the internal listener.
# Generate with: openssl rand -hex 32
OPEN_SANDBOX_INTERNAL_TOKEN=CHANGE_ME

# Maximum seconds the proxy waits for in-flight gateway IoSessions to drain
# after SIGTERM before sending each remaining stream a terminal Unavailable
# frame and exiting. Bounds the blast radius of a planned restart. Default: 30
#OPEN_SANDBOX_SHUTDOWN_DRAIN_TIMEOUT=30

# Optional. Set both TUNNEL_ACME_DOMAIN and ACME_EMAIL to enable automatic
# Let's Encrypt cert provisioning + rotation for the public proxy.
#TUNNEL_ACME_DOMAIN=sandbox.example.com
#ACME_EMAIL=ops@example.com
# Where on disk ACME caches the account key + certificates. Survive
# restarts; back up if you care about renewal continuity. Default: ./acme-cache
#ACME_CACHE_DIR=/mnt/data/acme-cache
# Set to 1/true/yes to use Let's Encrypt staging (untrusted certs, generous
# rate limits) for testing. Unset for production.
#ACME_STAGING=0


# ─────────────────────────────────────────────────────────────────────────────
# API gateway (open-sandbox api)
# ─────────────────────────────────────────────────────────────────────────────

# HTTP listen port for the REST + WebSocket API. Default: 8081
OPEN_SANDBOX_API_PORT=8081

# Controller gRPC address (lifecycle RPCs). Default: http://127.0.0.1:50051
OPEN_SANDBOX_CONTROLLER_URL=http://127.0.0.1:50051

# Proxy gRPC address for OpenIoStream — MUST be the proxy's INTERNAL listener
# (OPEN_SANDBOX_PROXY_INTERNAL_GRPC_PORT, default 50053). Dialing the public
# port (50052) is rejected with Unimplemented at the role gate.
# Default: http://127.0.0.1:50053
OPEN_SANDBOX_PROXY_URL=http://127.0.0.1:50053

# REQUIRED (fail-closed). Bearer key callers present to the REST API.
# Generate with: openssl rand -hex 32
OPEN_SANDBOX_API_KEY=CHANGE_ME

# REQUIRED when the proxy has OPEN_SANDBOX_INTERNAL_TOKEN set; must match.
# The api gateway sends this in the metadata of every OpenIoStream call.
# OPEN_SANDBOX_INTERNAL_TOKEN=...  (see above)

# REQUIRED when the api gateway calls controller management RPCs; must match
# the controller's value.
# CONTROLLER_ADMIN_TOKEN=...  (see above)

# Optional. Comma-separated CORS origins for browser callers. Set to "*"
# in dev only; production should list explicit origins. If unset, no CORS
# headers are emitted (same-origin only).
#OPEN_SANDBOX_API_CORS_ORIGINS=https://console.example.com,https://app.example.com


# ─────────────────────────────────────────────────────────────────────────────
# Agent (open-sandbox agent)
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. Same value as the controller's OPEN_SANDBOX_JOIN_TOKEN.
# OPEN_SANDBOX_JOIN_TOKEN=...  (see above)

# REQUIRED. Same value as the proxy's TUNNEL_JOIN_TOKEN.
# TUNNEL_JOIN_TOKEN=...  (see above)

# Controller gRPC address. In production, the agent dials this OVER the public
# internet (TLS); in dev / single-host this points to localhost.
# Default: http://127.0.0.1:50051
# OPEN_SANDBOX_CONTROLLER_URL=...  (see above)

# Proxy gRPC address — MUST be the proxy's PUBLIC listener
# (OPEN_SANDBOX_PROXY_GRPC_PORT, default 50052), NOT the internal one.
# Default: http://127.0.0.1:50052
# Note: the api gateway and the agent use the SAME variable name with
# DIFFERENT correct values. Set per-service in your deploy environment.
# OPEN_SANDBOX_PROXY_URL=http://127.0.0.1:50052
