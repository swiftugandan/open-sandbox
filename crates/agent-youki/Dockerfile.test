# CI / self-contained reproducer image for crates/agent-youki.
#
# For day-to-day iteration on macOS or any non-Linux host, prefer
# Dockerfile.dev + docker-compose.dev.yml: that flow keeps cargo's
# incremental compile alive across runs. This image rebuilds from scratch
# on every source change by design — reproducibility over iteration speed.
# A BuildKit cache mount was considered and rejected here: it would orphan
# the compiled artifacts from the image (cache mounts are build-time only),
# breaking the runtime `cargo test` invocation. If cold CI compile time
# becomes the bottleneck, the correct fix is multi-stage with explicit
# COPY of target/debug/deps into the runtime stage.

FROM rust:1.88-alpine

RUN apk add --no-cache \
    musl-dev \
    gcc \
    libseccomp-dev \
    libseccomp-static \
    pkgconf \
    protobuf-dev \
    git \
    iptables \
    util-linux

ENV LIBSECCOMP_LINK_TYPE=static
ENV LIBSECCOMP_LIB_PATH=/usr/lib

# Install CNI plugins
RUN wget -q https://github.com/containernetworking/plugins/releases/download/v1.6.2/cni-plugins-linux-amd64-v1.6.2.tgz \
    -O /tmp/cni-plugins.tgz \
    && mkdir -p /opt/cni/bin \
    && tar -xzf /tmp/cni-plugins.tgz -C /opt/cni/bin \
    && rm /tmp/cni-plugins.tgz

WORKDIR /build

COPY Cargo.toml Cargo.lock ./
COPY crates crates/
COPY proto proto/

RUN cargo test -p open-sandbox-agent-youki --no-run 2>&1

# Entrypoint script: cgroup v2 setup + exec the test command.
#
# On Docker Desktop's nested Linux VM (and on any host where this
# container's cgroup hasn't pre-delegated controllers), libcontainer
# fails to create sandboxes with:
#
#   failed to write +io to /sys/fs/cgroup/cgroup.subtree_control:
#   Not supported (os error 95)
#
# The fix: move all current procs into a leaf "init" cgroup (so the
# container's root cgroup has no processes, satisfying v2's no-internal-
# process constraint), then enable every available controller in the
# root's subtree_control. Libcontainer's own create_and_start can then
# enable + populate its child cgroup hierarchy normally.
RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -e' \
    'if [ -d /sys/fs/cgroup ] && [ -f /sys/fs/cgroup/cgroup.controllers ]; then' \
    '  mkdir -p /sys/fs/cgroup/init' \
    '  while read -r pid; do' \
    '    echo "$pid" > /sys/fs/cgroup/init/cgroup.procs 2>/dev/null || true' \
    '  done < /sys/fs/cgroup/cgroup.procs' \
    '  for c in $(cat /sys/fs/cgroup/cgroup.controllers); do' \
    '    echo "+$c" > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null || true' \
    '  done' \
    'fi' \
    'exec "$@"' \
    > /usr/local/bin/cgroup-v2-entrypoint.sh \
 && chmod +x /usr/local/bin/cgroup-v2-entrypoint.sh

ENTRYPOINT ["/usr/local/bin/cgroup-v2-entrypoint.sh"]
CMD ["cargo", "test", "-p", "open-sandbox-agent-youki", "--", "--nocapture"]
